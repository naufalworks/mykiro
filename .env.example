# Kiro Intelligent MCP Suite - Environment Variables

# Required: Anthropic API Key (or Bedrock credentials)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Custom Bedrock endpoint (default: https://api.anthropic.com)
ANTHROPIC_BASE_URL=http://3.68.219.151:20128/v1

# Required: Voyage AI API Key (for embeddings)
VOYAGE_API_KEY=your-voyage-api-key-here

# Optional: Qdrant configuration (default: localhost:6333)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Optional: Redis configuration (default: localhost:6379)
REDIS_HOST=localhost
REDIS_PORT=6379

# Optional: Model configuration
MODEL_NAME=kr/claude-sonnet-4.5

# Optional: Cache TTL in seconds (default: 3600)
CACHE_TTL=3600

# Optional: Max tokens for AI responses (default: 2048)
MAX_TOKENS=2048
